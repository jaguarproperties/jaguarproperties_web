generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  UPCOMING
  LAUNCHING
  COMPLETED
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  HOLD
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

enum MediaEntityType {
  PROJECT
  PROPERTY
  BLOG_POST
  SITE_CONTENT
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  HR
  MANAGER
  EMPLOYEE
  DEVELOPER
  DIGITAL
}

enum AttendanceWorkType {
  OFFICE
  WFH
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  HALF_DAY
}

enum LeaveType {
  CASUAL
  SICK
  PAID
  UNPAID
  OTHER
}

enum LeaveDuration {
  FULL_DAY
  FIRST_HALF
  SECOND_HALF
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationType {
  LEAVE_APPLIED
  LEAVE_STATUS
  ATTENDANCE_EDITED
  ATTENDANCE_ALERT
  ANNOUNCEMENT
}

model Role {
  id                    String   @id @default(cuid()) @map("_id")
  name                  String   @unique
  description           String?
  permissions           String[] @default([])
  canManageUsers        Boolean  @default(false)
  canManageRoles        Boolean  @default(false)
  canEditTheme          Boolean  @default(false)
  canEditContent        Boolean  @default(false)
  canManageImages       Boolean  @default(false)
  canEditBlog           Boolean  @default(false)
  canEditNews           Boolean  @default(false)
  canManageJobPostings  Boolean  @default(false)
  canViewApplications   Boolean  @default(false)
  canEditProjects       Boolean  @default(false)
  canEditProperties     Boolean  @default(false)
  canAccessAttendance   Boolean  @default(false)
  canAccessLeave        Boolean  @default(false)
  canManageAttendance   Boolean  @default(false)
  canApproveLeave       Boolean  @default(false)
  canViewAttendanceReports Boolean @default(false)
  canExportAttendance   Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model User {
  id                   String              @id @default(cuid()) @map("_id")
  username             String              @unique @default("jaguarproperties2023")
  employeeCode         String              @unique
  name                 String?
  email                String              @unique
  phone                String?
  passwordHash         String
  role                 UserRole            @default(ADMIN)
  department           String?
  reportingManagerId   String?
  defaultWorkType      AttendanceWorkType  @default(OFFICE)
  casualLeaveBalance   Float               @default(12)
  sickLeaveBalance     Float               @default(6)
  paidLeaveBalance     Float               @default(12)
  unpaidLeaveBalance   Float               @default(0)
  image                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  accounts             Account[]
  sessions             Session[]
  reportingManager     User?               @relation("ManagerReports", fields: [reportingManagerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teamMembers          User[]              @relation("ManagerReports")
  attendanceRecords    Attendance[]
  editedAttendanceRecords Attendance[]     @relation("AttendanceEditedBy")
  leaveRequests        LeaveRequest[]
  approvedLeaveRequests LeaveRequest[]     @relation("ApprovedLeaves")
  attendanceEditLogs   AttendanceEditLog[]
  leaveBalanceLogs     LeaveBalanceLog[]   @relation("LeaveBalanceEmployee")
  editedLeaveBalances  LeaveBalanceLog[]   @relation("LeaveBalanceEditor")
  notifications        Notification[]      @relation("UserNotifications")
  sentNotifications    Notification[]      @relation("NotificationSender")
  uploadedHolidays     Holiday[]           @relation("HolidayUploader")
}

model Notification {
  id          String           @id @default(cuid()) @map("_id")
  userId      String
  senderId    String?
  title       String
  message     String
  type        NotificationType
  isRead      Boolean          @default(false)
  redirectUrl String?
  eventKey    String?
  createdAt   DateTime         @default(now())
  user        User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sender      User?            @relation("NotificationSender", fields: [senderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, isRead, createdAt])
}

model Attendance {
  id                String             @id @default(cuid()) @map("_id")
  employeeId        String
  date              DateTime
  checkInTime       DateTime?
  checkOutTime      DateTime?
  workType          AttendanceWorkType @default(OFFICE)
  location          Json?
  status            AttendanceStatus   @default(PRESENT)
  isLate            Boolean            @default(false)
  workingMinutes    Int                @default(0)
  editedById        String?
  editReason        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  employee          User               @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  editedBy          User?              @relation("AttendanceEditedBy", fields: [editedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  editLogs          AttendanceEditLog[]

  @@unique([employeeId, date])
}

model LeaveRequest {
  id           String      @id @default(cuid()) @map("_id")
  employeeId   String
  leaveType    LeaveType
  leaveDuration LeaveDuration @default(FULL_DAY)
  startDate    DateTime
  endDate      DateTime
  reason       String
  status       LeaveStatus @default(PENDING)
  approvedById String?
  remarks      String?
  cancelledAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  employee     User        @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedBy   User?       @relation("ApprovedLeaves", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model AttendanceEditLog {
  id           String      @id @default(cuid()) @map("_id")
  attendanceId String?
  editorId     String
  reason       String
  previousData Json?
  nextData     Json?
  createdAt    DateTime    @default(now())
  attendance   Attendance? @relation(fields: [attendanceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  editor       User        @relation(fields: [editorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model LeaveBalanceLog {
  id              String   @id @default(cuid()) @map("_id")
  employeeId      String
  editorId        String
  previousBalance Float
  newBalance      Float
  note            String?
  createdAt       DateTime @default(now())
  employee        User     @relation("LeaveBalanceEmployee", fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  editor          User     @relation("LeaveBalanceEditor", fields: [editorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Holiday {
  id           String   @id @default(cuid()) @map("_id")
  date         DateTime @unique
  title        String
  description  String?
  uploadedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  uploadedBy   User?    @relation("HolidayUploader", fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Account {
  id                String  @id @default(cuid()) @map("_id")
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid()) @map("_id")
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid()) @map("_id")
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id              String         @id @default(cuid()) @map("_id")
  title           String
  slug            String         @unique
  summary         String
  description     String
  city            String
  location        String
  country         String
  priceRange      String
  status          ProjectStatus  @default(LAUNCHING)
  completionDate  DateTime?
  featured        Boolean        @default(false)
  coverImage      String
  gallery         String[]
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  properties      Property[]
  media           Media[]
}

model Property {
  id              String         @id @default(cuid()) @map("_id")
  title           String
  slug            String         @unique
  description     String
  city            String
  location        String
  address         String
  price           String
  bedrooms        Int?
  bathrooms       Int?
  areaSqFt        Int?
  status          PropertyStatus @default(AVAILABLE)
  featured        Boolean        @default(false)
  coverImage      String
  gallery         String[]
  projectId       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  media           Media[]
}

model BlogPost {
  id             String    @id @default(cuid()) @map("_id")
  title          String
  slug           String    @unique
  excerpt        String
  content        String
  coverImage     String
  seoTitle       String?
  seoDescription String?
  published      Boolean   @default(true)
  publishedAt    DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  media          Media[]
}

model Lead {
  id          String     @id @default(cuid()) @map("_id")
  name        String
  email       String
  phone       String
  message     String
  city        String?
  inquiryType String?
  status      LeadStatus @default(NEW)
  createdAt   DateTime   @default(now())
}

model JobApplication {
  id          String   @id @default(cuid()) @map("_id")
  role        String
  fullName    String
  email       String
  location    String
  phone       String
  joinDate    DateTime
  resumeUrl   String
  resumeName  String
  createdAt   DateTime @default(now())
}

model JobPosting {
  id            String   @id @default(cuid()) @map("_id")
  title         String
  department    String
  location      String
  description   String
  requirements  String
  openings      Int      @default(1)
  qualification String?
  experience    String?
  salary        String?
  type          String   @default("FULL_TIME")
  isActive      Boolean  @default(true)
  postedAt      DateTime @default(now())
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Media {
  id          String          @id @default(cuid()) @map("_id")
  url         String
  alt         String?
  entityType  MediaEntityType
  projectId   String?
  propertyId  String?
  blogPostId  String?
  contentId   String?
  createdAt   DateTime        @default(now())
  project     Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  property    Property?       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  blogPost    BlogPost?       @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  siteContent SiteContent?    @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model SiteContent {
  id               String    @id @default(cuid()) @map("_id")
  heroTitle        String
  heroSubtitle     String
  heroImage        String
  homePrimaryCtaLabel String?
  homePrimaryCtaHref  String?
  homeSecondaryCtaLabel String?
  homeSecondaryCtaHref  String?
  homePresenceLocations String?
  homeSignatureText     String?
  homeSpotlightLabel    String?
  homeSpotlightTitle    String?
  homeSpotlightText     String?
  homeSpotlightPrice    String?
  homeStats             String?
  aboutTitle       String
  aboutBody        String
  mission          String
  vision           String
  presenceText     String?
  homeFeaturedProjectsTitle       String?
  homeFeaturedProjectsDescription String?
  homeFeaturedPropertiesTitle       String?
  homeFeaturedPropertiesDescription String?
  homePortfolioTitle       String?
  homePortfolioDescription String?
  homePortfolioItems       String?
  homeNewsTitle            String?
  homeNewsDescription      String?
  homeConciergeTitle       String?
  homeConciergeButtonLabel String?
  homeConciergeButtonHref  String?
  projectsTitle            String?
  projectsDescription      String?
  projectsHighlights       String?
  propertiesTitle          String?
  propertiesDescription    String?
  propertiesHighlights     String?
  newsTitle                String?
  newsDescription          String?
  newsHighlights           String?
  portfolioTitle           String?
  portfolioDescription     String?
  portfolioGallery         String?
  contactTitle             String?
  contactDescription       String?
  contactSupportPoints     String?
  careersTitle             String?
  careersDescription       String?
  careersCulturePoints     String?
  contactEmail     String
  contactPhone     String
  officeAddress    String
  mapEmbedUrl      String
  footerBlurb      String    @default("Premium real estate experiences across Bengaluru, Doha, and Dubai.")
  footerCopyright  String    @default("© 2026 JAGUAR PROPERTIES. Premium real estate developer for Bengaluru, Qatar, and Dubai.")
  footerNote       String    @default("Designed for modern buyers, fast performance, and mobile responsiveness.")
  instagramUrl     String    @default("https://instagram.com")
  linkedinUrl      String    @default("https://linkedin.com")
  facebookUrl      String    @default("https://facebook.com")
  twitterUrl       String    @default("https://x.com")
  youtubeUrl       String    @default("https://youtube.com")
  media            Media[]
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())
}
